# ──────────────────────────────────────────────────────────────
# SAP Commerce ImpEx: Sample Customers for Recommendation Engine
# Import: Electronics storefront users with distinct buyer profiles
# ──────────────────────────────────────────────────────────────
#
# USER PROFILES (for collaborative + content filtering)
# ─────────────────────────────────────────────────────
# Each user is assigned a buyer persona so the recommendation engine
# can discover meaningful clusters and cross-sell opportunities.
#
# Cluster A – DSLR Pro Photographers
#   Alice Johnson      : DSLR + pro lenses + tripod + memory
#   Dave Chen          : DSLR + lens collector + flash
#   Grace Kim          : DSLR + lenses + flash + bag
#   Sam Harris         : DSLR + lenses + tripod + memory
#
# Cluster B – Compact Camera / Casual Users
#   Carol Martinez     : Compact cameras + memory + bag
#   Emma Thompson      : Compact cameras + bag + memory
#   Jack Robinson      : Compact cameras + memory + tripod
#   Peter Wilson       : Compact cameras + memory + tripod
#   Rachel Lee         : Compact cameras + bag + memory
#
# Cluster C – Video / Camcorder Enthusiasts
#   Bob Williams       : Camcorder + battery + tripod + memory
#   Frank Mueller      : Dual camcorders + battery + remote
#   Quinn Taylor       : Dual camcorders + tripod + memory
#   Tina Fernandez     : Camcorder + battery + bag + remote
#
# Cluster D – Accessories & Memory Power Buyers
#   Karen Okonkwo      : Memory + battery + bag + flash
#   Mia Anderson       : Memory + tripod + bag + remote
#   Noah Brown         : Battery + tripod + memory + flash
#
# Bridge Users (connect clusters for collaborative filtering)
#   Henry Patel        : Compact + Accessories (B↔D)
#   Iris Nakamura      : DSLR + Accessories (A↔D)
#   Liam Garcia        : Video + DSLR (C↔A)
#   Olivia Davis       : DSLR + Compact (A↔B)
#
# ──────────────────────────────────────────────────────────────

$defaultPassword = 1234567890
$siteUid = electronics

# ── Customer Group ───────────────────────────────────────────
INSERT_UPDATE UserGroup; uid[unique = true]; locname[lang = en]
; customergroup ; Customer Group

# ── Customers ────────────────────────────────────────────────
INSERT_UPDATE Customer; uid[unique = true]          ; name                ; customerID          ; &userRef          ; groups(uid)    ; sessionLanguage(isocode) ; sessionCurrency(isocode) ; password[default = $defaultPassword]
# Cluster A – DSLR Pro Photographers
                      ; alice@email.com     ; Alice Johnson       ; CUST-001            ; aliceRef          ; customergroup  ; en                       ; USD
