# ──────────────────────────────────────────────────────────────
# SAP Commerce ImpEx: Sample Orders for Recommendation Engine
# Historical order data used for collaborative filtering
# Product codes match the standard SAP Electronics accelerator
# ──────────────────────────────────────────────────────────────
#
# RECOMMENDATION DESIGN
# ─────────────────────
# Users are grouped into 4 clusters + bridge users. Each cluster shares
# a core set of products but individual users have gaps, so collaborative
# filtering can surface products that "users like you" bought.
#
# Expected recommendations (collaborative + content):
#   Alice (DSLR Pro)    → 482105 (lens), 479956 (flash), 1934406 (bag)
#   Carol (Compact)     → 1986316 (DSC-T90), 898503 (tripod)
#   Bob   (Video)       → 1934793 (camcorder), 458542 (remote)
#   Karen (Accessories) → 898503 (tripod), 458542 (remote)
#
# Product reference (16 products across 6 categories):
#   DSLR Camera   : 1382080 = Canon EOS 450D
#   Compact Cams  : 2934302 = PowerShot A480
#                   816324  = Cyber-shot DSC-W180
#                   1986316 = Cyber-shot DSC-T90
#                   325414  = DSC-N2
#   Camcorders    : 1934796 = HDR-CX105E
#                   1934793 = HDR-CX105E (variant)
#   Pro Lenses    : 1366053 = Canon EF 100mm f/2.8
#                   493683  = EF 70-300mm IS USM
#                   482105  = EF 75-300mm III USM
#   Memory        : 4812254 = Kingston 16GB SDHC
#   Accessories   : 898503  = Tripod
#                   1934406 = Camera Bag
#                   278688  = Battery Pack
#                   479956  = Flash HVL-F58AM
#                   458542  = Remote Commander
#
# ──────────────────────────────────────────────────────────────

$siteUid = electronics
$currency = USD
$deliveryMode = standard-gross
$catalogVersion = electronicsProductCatalog:Online

# ── Orders ───────────────────────────────────────────────────

INSERT_UPDATE Order; code[unique = true] ; user(uid)                    ; currency(isocode) ; date[dateformat = dd.MM.yyyy] ; deliveryMode(code)   ; net    ; calculated ; site(uid)   ; store(uid)  ; status(code)
