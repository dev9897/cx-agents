# ──────────────────────────────────────────────────────────────
# SAP Commerce ImpEx: Sample Orders for Recommendation Engine
# Historical order data used for collaborative filtering
# Product codes match the standard SAP Electronics accelerator
# ──────────────────────────────────────────────────────────────

$siteUid = electronics
$currency = USD
$deliveryMode = standard-gross
$catalogVersion = electronicsProductCatalog:Online

# ── Orders ───────────────────────────────────────────────────
# Creates historical orders for each customer with diverse product mix
# This enables the collaborative filtering algorithm to find patterns:
#   - Alice & Bob both bought cameras → recommend similar items
#   - Users who bought cameras also bought memory cards & tripods
#   - Power users buy accessories → cross-sell opportunities

INSERT_UPDATE Order; code[unique = true] ; user(uid)                    ; currency(isocode) ; date[dateformat = dd.MM.yyyy] ; deliveryMode(code)   ; net    ; calculated ; site(uid)   ; store(uid)  ; status(code)
                   ; ORD-A001            ; alice@email.com      ; USD               ; 15.01.2026                    ; $deliveryMode        ; false  ; true       ; $siteUid    ; $siteUid    ; COMPLETED
                   ; ORD-A002            ; alice@email.com      ; USD               ; 28.02.2026                    ; $deliveryMode        ; false  ; true       ; $siteUid    ; $siteUid    ; COMPLETED
