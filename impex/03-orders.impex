# ── Order Entries ────────────────────────────────────────────
# Realistic product codes from SAP Electronics Accelerator catalog
# Pattern: camera users also buy lenses/memory cards/tripods (collaborative signal)

INSERT_UPDATE OrderEntry; order(code)[unique = true] ; entryNumber[unique = true] ; product(code, catalogVersion(catalog(id), version))[unique = true] ; quantity ; unit(code)
# Alice: Camera enthusiast (DSLR + lenses + memory cards)
                        ; ORD-A001                   ; 0                          ; 1382080:$catalogVersion ; 1        ; pieces     # EOS 450D
                        ; ORD-A001                   ; 1                          ; 4812254:$catalogVersion ; 2        ; pieces     # 16GB SD Card
                        ; ORD-A002                   ; 0                          ; 2934302:$catalogVersion ; 1        ; pieces     # Powershot A480
                        ; ORD-A002                   ; 1                          ; 1366053:$catalogVersion ; 1        ; pieces     # Canon EF Lens
                        ; ORD-A003                   ; 0                          ; 898503:$catalogVersion  ; 1        ; pieces     # Tripod
                        ; ORD-A003                   ; 1                          ; 1934406:$catalogVersion ; 1        ; pieces     # Camera Bag

