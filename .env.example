# ── LLM Provider: "anthropic" (Claude) or "gemini" (Google Gemini) ────────────
LLM_PROVIDER=anthropic

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-haiku-4-5
ANTHROPIC_BASE_URL=https://api.anthropic.com
max_tokens=1024
max_input_tokens=4000

# ── Google Gemini ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── SAP Commerce Cloud ────────────────────────────────────────────────────────
SAP_BASE_URL=https://your-sap-instance.example.com/occ/v2
SAP_OCC_PREFIX=/occ/v2
SAP_SITE_ID=electronics
SAP_CLIENT_ID=cx_agent_client
SAP_CLIENT_SECRET=secret
SAP_SSL_VERIFY=false

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_PORT=8005
MCP_TRANSPORT=sse
HOST=127.0.0.1

# ── LangChain ─────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false

# ── Qdrant Vector DB ──────────────────────────────────────────────────────────
# Cloud:  QDRANT_HOST=https://xxxx.qdrant.io   QDRANT_API_KEY=your-key
# Local:  QDRANT_HOST=http://localhost:6333     QDRANT_API_KEY=   (leave blank)
QDRANT_HOST=
QDRANT_API_KEY=

# ── Stripe (required for checkout & card saving) ─────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ── Agentic Commerce Protocol (ACP) ────────────────────────────────────────
ACP_API_KEY=
ACP_HMAC_SECRET=
ACP_CURRENCY=USD
ACP_STORE_URL=
